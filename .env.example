# RiskLens — Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://RiskLens:RiskLens@localhost:5432/RiskLens_db
POSTGRES_USER=RiskLens
POSTGRES_PASSWORD=RiskLens
POSTGRES_DB=RiskLens_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Market Data
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5155,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
CLAUDE_RATE_LIMIT_PER_HOUR=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

